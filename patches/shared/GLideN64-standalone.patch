+		presenterActive = overlay_sdl_present_active() != 0;
+		if (presenterActive)
+			overlay_sdl_present_bind_target();
+	});
+	if (!presenterActive)
+		gfxContext.bindFramebuffer(bufferTarget::DRAW_FRAMEBUFFER, ObjectHandle::defaultFramebuffer);
+}
