+namespace opengl {
+class OverlayCallbackCommand : public OpenGlCommand {
+public:
+	OverlayCallbackCommand() : OpenGlCommand(true, false, "OverlayCallback", false) {}
+
+	static std::shared_ptr<OpenGlCommand> get(std::function<void()> callback) {
+		static int poolId = OpenGlCommandPool::get().getNextAvailablePool();
+		auto ptr = getFromPool<OverlayCallbackCommand>(poolId);
+		ptr->m_callback = std::move(callback);
+		return ptr;
+	}
+
+	void commandToExecute() override {
+		m_callback();
+		m_callback = nullptr; // release captured state promptly
+	}
+private:
+	std::function<void()> m_callback;
+};
+}
+
+static void gliden64_core_swap_buffers(void) {
+	::CoreVideo_GL_SwapBuffers();
+}
+
+static void gliden64_swap_buffers(void) {
+	overlay_sdl_present_swap(gliden64_core_swap_buffers);
+}
+
+// Return the overlay render backend (plugin_ops.get_render)
+static EmuOvlRenderBackend* gliden64_get_render(void) {
+	return overlay_sdl_get_backend();
+}
+
+// Cycle aspect ratio (plugin_ops.cycle_aspect). Writes the new value into the
+// overlay config so the Options menu reflects it.
+static void gliden64_cycle_aspect(void) {
+	// GLideN64: aStretch=0, a43=1, a169=2, aAdjust43=3
+	// Cycle: Auto(3) → 4:3(1) → 16:9(2) → Stretch(0) → Auto(3)
+	int cur = config.frameBufferEmulation.aspect;
+	switch (cur) {
+		case 3: cur = 1; break;  // Auto → 4:3
+		case 1: cur = 2; break;  // 4:3 → 16:9
+		case 2: cur = 0; break;  // 16:9 → Stretch
+		default: cur = 3; break; // Stretch (or other) → Auto
+	}
+	config.frameBufferEmulation.aspect = cur;
+	// Sync overlay config so the menu shows the updated value
+	EmuOvlConfig* cfg = emu_frontend_get_overlay_config();
+	if (cfg) {
+		for (int s = 0; s < cfg->section_count; s++)
+			for (int i = 0; i < cfg->sections[s].item_count; i++)
+				if (strcmp(cfg->sections[s].items[i].key, "AspectRatio") == 0) {
+					cfg->sections[s].items[i].current_value = cur;
+					cfg->sections[s].items[i].staged_value = cur;
+				}
+	}
+}
+
+// Dispatch a function on the video/GL thread (plugin_ops.exec_on_video_thread).
+// Threaded mode: wraps in OverlayCallbackCommand. Non-threaded: direct call.
+static void gliden64_exec_on_video_thread(void (*fn)(void*), void* ctx) {
+	if (opengl::FunctionWrapper::isThreadedMode()) {
+		opengl::FunctionWrapper::executeOverlayCommand(
+			opengl::OverlayCallbackCommand::get([fn, ctx]() {
+				fn(ctx);
+			})
+		);
+	} else {
+		fn(ctx);
+	}
+}
+
+typedef struct {
+	int w;
+	int h;
+} HudRenderCtx;
+
+static void gliden64_render_hud_on_gl_thread(void* data) {
+	HudRenderCtx* ctx = (HudRenderCtx*)data;
+	emu_frontend_render_hud(ctx->w, ctx->h);
+}
+
