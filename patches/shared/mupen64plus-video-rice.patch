+    // Compute effective display dimensions based on aspect ratio
+    unsigned short dispW = windowSetting.uDisplayWidth;
+    unsigned short dispH = windowSetting.uDisplayHeight;
+    unsigned short effW = dispW;
+    unsigned short effH = dispH;
+
+    int ar = options.aspectRatio;
+    if (ar == 3) ar = 1;  // Auto = 4:3
+
+    if (ar == 1) {  // Force 4:3
+        if (dispW * 3 > dispH * 4) {
+            effW = dispH * 4 / 3;
+        } else if (dispH * 4 > dispW * 3) {
+            effH = dispW * 3 / 4;
+        }
+    } else if (ar == 2) {  // Force 16:9
+        if (dispW * 9 > dispH * 16) {
+            effW = dispH * 16 / 9;
+        } else if (dispH * 16 > dispW * 9) {
+            effH = dispW * 9 / 16;
+        }
+    }
+    // ar == 0 (Stretch): use full display dims (already set)
+
+    windowSetting.uEffDisplayWidth = effW;
+    windowSetting.uEffDisplayHeight = effH;
+    windowSetting.vpBaseX = (dispW - effW) / 2;
+    windowSetting.vpBaseY = (dispH - effH) / 2;
+
+    SetScreenMult(effW / windowSetting.fViWidth, effH / windowSetting.fViHeight);
 }
